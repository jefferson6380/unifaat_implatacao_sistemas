# Banco de dados (IP privado da instância EC2 de banco)
DB_HOST=10.0.2.x
DB_USER=appuser
DB_PASSWORD=SecurePass123!
DB_NAME=portfolio_db

# Segurança
ALLOWED_ORIGIN=http://<ip-publico-do-ec2>
CSRF_TOKEN=<token-secreto-aleatorio>

# Metadados da instância (preenchidos automaticamente no EC2)
INSTANCE_ID=i-xxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
